# Copy this file to `.env` and fill in your own values before running the project locally.
# On Replit/Vercel, set these values in Secrets or Environment Variables.

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database
# Example: postgres://user:password@localhost:5432/hgss_school
DATABASE_URL=

# Session
# Any long random string used to sign session cookies.
SESSION_SECRET=

# Diyana Chatbot (Groq)
# Get a free key from https://console.groq.com/keys
GROQ_API_KEY=

# Text-to-speech (optional, ElevenLabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=
